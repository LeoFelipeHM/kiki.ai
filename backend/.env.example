DATABASE_URL=

OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5.4-mini
OPENAI_CHAT_MODEL=gpt-5.4-mini

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
KIKI_VOICE_AGENT_NAME=kiki-voice

# Voice runtime:
# - classic: AssemblyAI STT + OpenAI Responses multimodal + Azure TTS
# O modo classic é usado para garantir que os frames da câmera sejam anexados ao modelo.
KIKI_VOICE_MODE=classic
# Use apenas modelos multimodais. O backend ignora valores texto-only e usa o fallback multimodal.
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SPEED=1.0

# Required only when KIKI_VOICE_MODE=classic
ASSEMBLYAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_VOICE_NAME=pt-BR-FranciscaNeural
AZURE_TTS_SAMPLE_RATE=24000
