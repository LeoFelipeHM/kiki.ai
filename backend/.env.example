DATABASE_URL=
CORS_ORIGINS=https://app.heykiki.com.br,https://heykiki.com.br,https://www.heykiki.com.br,https://api.heykiki.com.br
CORS_ORIGIN_REGEX=

OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5.4-nano
OPENAI_CHAT_MODEL=gpt-5.4-nano
OPENAI_AGENT_PLANNER_ENABLED=false
OPENAI_RATE_LIMIT_MAX_RETRIES=1
OPENAI_RATE_LIMIT_BACKOFF_SECONDS=2

# Agent token/call controls
AGENT_OPENAI_MIN_SECONDS_BETWEEN_CALLS=0
AGENT_OPENAI_MAX_CALLS_PER_AGENT=3
AGENT_OPENAI_MAX_TOOL_TURNS_STEP=2
AGENT_OPENAI_MAX_TOOL_TURNS_FINAL=2
AGENT_OPENAI_WEB_SEARCH_CONTEXT_SIZE=low
AGENT_OPENAI_DEFAULT_MODEL=gpt-5.4-nano
AGENT_OPENAI_HIGH_MODEL=gpt-5.4-mini
# Optional overrides: minimal | low | medium | high | xhigh
AGENT_OPENAI_REASONING_EFFORT_LOW=minimal
AGENT_OPENAI_REASONING_EFFORT_MEDIUM=low
AGENT_OPENAI_REASONING_EFFORT_HIGH=medium

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
KIKI_VOICE_AGENT_NAME=kiki-voice

# Voice runtime:
# - classic: AssemblyAI STT + OpenAI Responses multimodal + Azure TTS
# O modo classic é usado para garantir que os frames da câmera sejam anexados ao modelo.
KIKI_VOICE_MODE=classic
# Use apenas modelos multimodais. O backend ignora valores texto-only e usa o fallback multimodal.
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SPEED=1.0

# Required only when KIKI_VOICE_MODE=classic
ASSEMBLYAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_VOICE_NAME=pt-BR-FranciscaNeural
AZURE_TTS_SAMPLE_RATE=24000
